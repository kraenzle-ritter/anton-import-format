{
    "name": "kraenzle-ritter/anton-import-format",
    "description": "JSON-Schema (Draft 2020-12) and Validator for the Anton archive system's metadata.json import format. Single source of truth for both the agate SIP producer and Anton's Excel importer.",
    "type": "library",
    "license": "MIT",
    "keywords": ["anton", "agate", "json-schema", "validation", "archival", "digital-preservation", "ingest", "metadata"],
    "homepage": "https://github.com/kraenzle-ritter/anton-import-format",
    "support": {
        "issues": "https://github.com/kraenzle-ritter/anton-import-format/issues",
        "source": "https://github.com/kraenzle-ritter/anton-import-format"
    },
    "autoload": {
        "psr-4": {
            "KraenzleRitter\\AntonImportFormat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KraenzleRitter\\AntonImportFormat\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "opis/json-schema": "^2.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        { "name": "Kraenzle & Ritter", "email": "info@k-r.ch" }
    ]
}
